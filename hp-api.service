[Unit]
Description=Xcel HeatPump API Service
After=network.target redis.service
Wants=network.target

[Service]
Type=simple
User=jeffrey
Group=jeffrey
WorkingDirectory=/home/jeffrey/Xcel-HeatPump
Environment=PYTHONUNBUFFERED=1
ExecStart=/bin/bash -lc 'poetry run python -m api_src.hp_api.main'
Restart=always
RestartSec=3
StartLimitIntervalSec=0

[Install]
WantedBy=multi-user.target
